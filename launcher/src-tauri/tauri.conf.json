{
  "productName": "OpenDayZ Launcher",
  "version": "0.1.0",
  "identifier": "com.opendayz.launcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420", 
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "OpenDayZ Launcher",
        "width": 900,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}